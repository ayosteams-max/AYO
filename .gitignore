# Python bytecode and interpreter caches
__pycache__/
*.py[cod]
*$py.class

# Local Python environments
.venv/
venv/
env/
ENV/

# Packaging and build output
build/
dist/
*.egg-info/
.eggs/

# Test, coverage, type-checker and linter caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.uv-cache/
.tools/
.tox/
.nox/

# Local configuration and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Runtime output and local data
*.log
logs/
*.sqlite
*.sqlite3
*.db

# Editors and operating systems
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
~$*
